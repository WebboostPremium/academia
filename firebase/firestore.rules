rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuth() && userDoc().data.role == 'admin';
    }

    function isCatequista() {
      return isAuth() && userDoc().data.role == 'catequista';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isCatequista();
      allow create: if false;
      allow update: if isAdmin() || (isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status']));
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if resource.data.status == 'published' || isAdmin() || isCatequista();
      allow write: if isAdmin();
    }

    match /modules/{moduleId} {
      allow read: if isAdmin() || isCatequista() || isAuth();
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isAdmin() || isCatequista() || isAuth();
      allow write: if isAdmin() || isCatequista();
    }

    match /quizzes/{quizId} {
      allow read: if isAdmin() || isCatequista() || isAuth();
      allow write: if isAdmin() || isCatequista();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || isCatequista()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /certificates/{certId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /forum_questions/{questionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin() || isCatequista();
    }

    match /forum_answers/{answerId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || isCatequista());
      allow update, delete: if isAdmin() || isCatequista();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isCatequista();
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin() || isCatequista()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin() || isCatequista();
    }

    match /live_classes/{classId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isCatequista();
    }

    match /sacramental_records/{recordId} {
      allow read: if isAdmin() || isCatequista()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isCatequista();
    }

    match /gallery_albums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{articleId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /prayers/{prayerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /prayer_progress/{docId} {
      allow read, write: if isAuth()
        && (resource == null || resource.data.userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /email_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
