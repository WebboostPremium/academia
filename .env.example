# ═══════════════════════════════════════════════════════════════
# CATEQUESIS ONLINE — Variables de entorno
# Copia este archivo a .env.local y completa los valores
# ═══════════════════════════════════════════════════════════════

# ─── FIREBASE (Cliente — públicas, van en el navegador) ───
# Obtener en: Firebase Console → Configuración del proyecto → Tus apps → Web
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── APP ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Producción: https://catequesisreinadelapaz.com
# Cookie compartida entre www y dominio raíz (opcional en producción):
SESSION_COOKIE_DOMAIN=

# ─── FIREBASE ADMIN (Servidor — NUNCA commitear ni exponer) ───
# Obtener en: Firebase Console → Configuración → Cuentas de servicio → Generar clave privada
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── SESIÓN JWT (Servidor) ───
# Genera uno aleatorio: openssl rand -base64 32
SESSION_SECRET=

# ─── WOMPI EL SALVADOR (Servidor — Enlaces de Pago + Webhook) ───
# Panel Wompi → Negocio → App ID = client_id, API Secret = client_secret
WOMPI_AUTH_URL=https://id.wompi.sv/connect/token
WOMPI_API_URL=https://api.wompi.sv
WOMPI_CLIENT_ID=
WOMPI_CLIENT_SECRET=
# Alias opcionales (mismos valores):
WOMPI_APP_ID=
WOMPI_PRIVATE_KEY=
# Opcional: correo para notificaciones de Wompi
WOMPI_NOTIFICATION_EMAIL=

# ─── CLOUDINARY (Servidor — imágenes, PDFs, certificados) ───
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
# Opción A: API Key + Secret (subida firmada)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Opción B: Upload preset sin firma (ej. Vendedores)
CLOUDINARY_UPLOAD_PRESET=

# ─── CORREO POST-COMPRA (Servidor — opcional) ───
# Obtener en: https://resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@catequesis.online
EMAIL_FROM_NAME=Catequesis Online

# ─── SEED EN PRODUCCIÓN (opcional) ───
# ALLOW_SEED=true
